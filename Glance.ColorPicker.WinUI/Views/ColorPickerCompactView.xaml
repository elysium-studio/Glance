<UserControl
    x:Class="Glance.ColorPicker.WinUI.ColorPickerCompactView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <ResourceDictionary Source="../Themes/ColorPicker.xaml" />
    </UserControl.Resources>
    <Grid Padding="8,0" ColumnSpacing="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Border
            x:Name="ColorSwatch"
            Width="30"
            Height="30"
            Background="{x:Bind ToBrush(ViewModel.CurrentColor), Mode=OneWay}"
            BorderBrush="{ThemeResource ControlStrokeColorSecondaryBrush}"
            BorderThickness="1"
            CornerRadius="8" />
        <TextBlock
            Grid.Column="1"
            VerticalAlignment="Center"
            FontSize="18"
            FontWeight="SemiBold"
            Foreground="{ThemeResource TextFillColorPrimaryBrush}"
            Text="{x:Bind ViewModel.Hex, Mode=OneWay}" />
    </Grid>
</UserControl>

<UserControl
    x:Class="Glance.Timer.WinUI.TimerCompactView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid x:Name="LayoutRoot" Padding="10,0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid
            x:Name="StatusIndicator"
            Width="26"
            Height="26"
            UseLayoutRounding="True">
            <Viewbox
                Width="24"
                Height="24"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
                <Canvas Width="14" Height="14">
                    <Ellipse
                        Canvas.Left="1.5"
                        Canvas.Top="1.5"
                        Width="11"
                        Height="11"
                        Stroke="{ThemeResource GlanceTimerIconBrush}"
                        StrokeThickness="0.9" />
                    <Path
                        Data="M 7,4 L 7,7.1 L 9.2,8.35"
                        Stroke="{ThemeResource GlanceTimerIconBrush}"
                        StrokeEndLineCap="Round"
                        StrokeLineJoin="Round"
                        StrokeStartLineCap="Round"
                        StrokeThickness="0.9" />
                </Canvas>
            </Viewbox>
        </Grid>
        <TextBlock
            Grid.Column="1"
            Margin="8,0,0,0"
            VerticalAlignment="Center"
            FontSize="15"
            FontWeight="SemiBold"
            Foreground="{ThemeResource TextFillColorPrimaryBrush}"
            Text="{Binding RemainingText}" />
    </Grid>
</UserControl>

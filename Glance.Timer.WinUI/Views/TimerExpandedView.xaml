<UserControl
    x:Class="Glance.Timer.WinUI.TimerExpandedView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid x:Name="LayoutRoot" Padding="20,12,20,26">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <Grid
            x:Name="StatusIndicator"
            Width="36"
            Height="36"
            VerticalAlignment="Center"
            UseLayoutRounding="True">
            <Viewbox
                Width="30"
                Height="30"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
                <Canvas Width="14" Height="14">
                    <Ellipse
                        Canvas.Left="1.5"
                        Canvas.Top="1.5"
                        Width="11"
                        Height="11"
                        Stroke="{ThemeResource GlanceTimerIconBrush}"
                        StrokeThickness="0.9" />
                    <Path
                        Data="M 7,4 L 7,7.1 L 9.2,8.35"
                        Stroke="{ThemeResource GlanceTimerIconBrush}"
                        StrokeEndLineCap="Round"
                        StrokeLineJoin="Round"
                        StrokeStartLineCap="Round"
                        StrokeThickness="0.9" />
                </Canvas>
            </Viewbox>
        </Grid>
        <StackPanel
            Grid.Column="1"
            Margin="12,0,12,0"
            VerticalAlignment="Center"
            Spacing="2">
            <TextBlock
                FontSize="11"
                FontWeight="SemiBold"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="TIMER" />
            <TextBlock
                FontSize="27"
                FontWeight="SemiBold"
                Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                Text="{Binding RemainingText}" />
        </StackPanel>
        <StackPanel
            Grid.Column="2"
            VerticalAlignment="Center"
            Orientation="Horizontal"
            Spacing="5">
            <Button
                Height="32"
                Padding="12,0"
                Command="{Binding AddMinuteCommand}"
                Content="+1 min"
                CornerRadius="16" />
            <Button
                Height="32"
                MinWidth="62"
                Padding="14,0"
                Command="{Binding ToggleCommand}"
                Content="{Binding ToggleText}"
                CornerRadius="16"
                Style="{StaticResource AccentButtonStyle}" />
            <Button
                Width="32"
                Height="32"
                Padding="0"
                Command="{Binding ResetCommand}"
                Content="&#xE777;"
                CornerRadius="16"
                FontFamily="Segoe Fluent Icons"
                ToolTipService.ToolTip="Reset" />
        </StackPanel>
    </Grid>
</UserControl>

<UserControl
    x:Class="Glance.Timer.WinUI.TimerExpandedView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <ResourceDictionary Source="../Themes/Timer.xaml" />
    </UserControl.Resources>
    <Grid x:Name="LayoutRoot" Padding="20,12,20,26" ColumnSpacing="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <Grid
            x:Name="StatusIndicator"
            Width="36"
            Height="36"
            VerticalAlignment="Center">
            <FontIcon
                Width="30"
                Height="30"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontFamily="Segoe Fluent Icons"
                FontSize="30"
                Foreground="{ThemeResource GlanceTimerIconBrush}"
                Glyph="&#xE917;" />
        </Grid>
        <StackPanel
            Grid.Column="1"
            VerticalAlignment="Center"
            Spacing="2">
            <TextBlock
                FontWeight="SemiBold"
                Foreground="{ThemeResource GlanceTimerIconBrush}"
                Style="{StaticResource CaptionTextBlockStyle}"
                Text="{x:Bind ToUpper(Title)}" />
            <TextBlock
                Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                Style="{StaticResource TitleTextBlockStyle}"
                Text="{x:Bind ViewModel.RemainingText, Mode=OneWay}" />
        </StackPanel>
        <StackPanel
            Grid.Column="2"
            VerticalAlignment="Center"
            Orientation="Horizontal"
            Spacing="5">
            <Button
                x:Uid="DecreaseButton"
                Width="32"
                Height="32"
                Padding="0"
                Click="{x:Bind ViewModel.DecreaseMinute}"
                Content="&#xE738;"
                CornerRadius="16"
                FontFamily="Segoe Fluent Icons"
                FontSize="14"
                IsEnabled="{x:Bind ViewModel.CanDecreaseMinute, Mode=OneWay}" />
            <Button
                x:Uid="IncreaseButton"
                Width="32"
                Height="32"
                Padding="0"
                Click="{x:Bind ViewModel.AddMinute}"
                Content="&#xE710;"
                CornerRadius="16"
                FontFamily="Segoe Fluent Icons"
                FontSize="14" />
            <Button
                x:Uid="ToggleButton"
                Width="36"
                Height="36"
                Padding="0"
                Click="{x:Bind ViewModel.Toggle}"
                Content="{x:Bind ViewModel.ToggleGlyph, Mode=OneWay}"
                CornerRadius="18"
                FontFamily="Segoe Fluent Icons"
                FontSize="16"
                Style="{StaticResource AccentButtonStyle}" />
            <Button
                x:Uid="ResetButton"
                Width="32"
                Height="32"
                Padding="0"
                Click="{x:Bind ViewModel.Reset}"
                Content="&#xE777;"
                CornerRadius="16"
                FontFamily="Segoe Fluent Icons"
                FontSize="14" />
        </StackPanel>
    </Grid>
</UserControl>

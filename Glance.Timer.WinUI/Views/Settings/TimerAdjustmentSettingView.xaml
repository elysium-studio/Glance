<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="Glance.Timer.WinUI.TimerAdjustmentSettingView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:CommunityToolkit="using:CommunityToolkit.WinUI.Controls"
    Loaded="{x:Bind ViewModel.Activate}"
    Unloaded="{x:Bind ViewModel.Deactivate}">
    <CommunityToolkit:SettingsCard x:Uid="TimerAdjustmentSettingCard">
        <NumberBox
            Minimum="0.5"
            Maximum="60"
            SmallChange="0.5"
            SpinButtonPlacementMode="Compact"
            Value="{x:Bind ViewModel.Value, Mode=TwoWay}" />
    </CommunityToolkit:SettingsCard>
</UserControl>

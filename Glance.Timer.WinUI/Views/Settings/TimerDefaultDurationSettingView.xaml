<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="Glance.Timer.WinUI.TimerDefaultDurationSettingView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:CommunityToolkit="using:CommunityToolkit.WinUI.Controls"
    Loaded="{x:Bind ViewModel.Activate}"
    Unloaded="{x:Bind ViewModel.Deactivate}">
    <CommunityToolkit:SettingsCard x:Uid="TimerDefaultDurationSettingCard">
        <NumberBox
            Minimum="1"
            Maximum="1440"
            SmallChange="1"
            SpinButtonPlacementMode="Compact"
            Value="{x:Bind ViewModel.Value, Mode=TwoWay}" />
    </CommunityToolkit:SettingsCard>
</UserControl>

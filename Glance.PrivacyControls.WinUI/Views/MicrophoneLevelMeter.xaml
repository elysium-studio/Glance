<UserControl
    x:Class="Glance.PrivacyControls.WinUI.MicrophoneLevelMeter"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Loaded="{x:Bind HandleLoaded}"
    SizeChanged="{x:Bind HandleSizeChanged}"
    Unloaded="{x:Bind HandleUnloaded}">
    <UserControl.Resources>
        <ResourceDictionary Source="../Themes/PrivacyControls.xaml" />
    </UserControl.Resources>
    <Grid IsHitTestVisible="False">
        <Border
            Height="1"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Center"
            Background="{ThemeResource GlancePrivacyControlsTrackBrush}" />
        <Grid
            x:Name="LevelPanel"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Center" />
    </Grid>
</UserControl>

<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="Local Elysium" value="C:\Users\dan\source\packages" />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
    <add key="Elysium Studio" value="https://nuget.pkg.github.com/elysium-studio/index.json" />
  </packageSources>
  <packageSourceMapping>
    <packageSource key="Local Elysium">
      <package pattern="Elysium.*" />
    </packageSource>
    <packageSource key="nuget.org">
      <package pattern="CommunityToolkit.*" />
      <package pattern="Microsoft.*" />
      <package pattern="NAudio*" />
      <package pattern="runtime.*" />
      <package pattern="System.*" />
      <package pattern="WinUIEx" />
      <package pattern="xunit*" />
    </packageSource>
    <packageSource key="Elysium Studio">
      <package pattern="Elysium.*" />
    </packageSource>
  </packageSourceMapping>
</configuration>

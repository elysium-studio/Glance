<UserControl
    x:Class="Glance.AudioSwitcher.WinUI.AudioSwitcherExpandedView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Controls="using:Elysium.UI.Controls.WinUI">
    <UserControl.Resources>
        <ResourceDictionary Source="../Themes/AudioSwitcher.xaml" />
    </UserControl.Resources>
    <Grid Padding="20,12,20,26" ColumnSpacing="18">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <Grid
            x:Name="StatusIndicator"
            Width="36"
            Height="36"
            VerticalAlignment="Center">
            <FontIcon
                Width="30"
                Height="30"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontFamily="Segoe Fluent Icons"
                FontSize="30"
                Foreground="{ThemeResource GlanceAudioSwitcherIconBrush}"
                Glyph="&#xE767;" />
        </Grid>
        <StackPanel
            Grid.Column="1"
            VerticalAlignment="Center"
            Spacing="2">
            <TextBlock
                FontWeight="SemiBold"
                Foreground="{ThemeResource GlanceAudioSwitcherIconBrush}"
                Style="{StaticResource CaptionTextBlockStyle}"
                Text="{x:Bind ToUpper(Title)}" />
            <Controls:MarqueeTextBlock
                Height="28"
                FontSize="20"
                FontWeight="SemiBold"
                Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                Text="{x:Bind ViewModel.CurrentDeviceName, Mode=OneWay}"
                ToolTipService.ToolTip="{x:Bind ViewModel.CurrentDeviceName, Mode=OneWay}"
                Visibility="{x:Bind WhenDeviceAvailable(ViewModel.DevicePositionText), Mode=OneWay}" />
            <TextBlock
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Style="{StaticResource BodyTextBlockStyle}"
                Text="{x:Bind ViewModel.CurrentDeviceName, Mode=OneWay}"
                TextTrimming="CharacterEllipsis"
                Visibility="{x:Bind WhenDeviceUnavailable(ViewModel.DevicePositionText), Mode=OneWay}" />
        </StackPanel>
        <StackPanel
            Grid.Column="2"
            VerticalAlignment="Center"
            Orientation="Horizontal"
            Spacing="4">
            <Button
                x:Uid="PreviousButton"
                Width="32"
                Height="32"
                Padding="0"
                Click="{x:Bind ViewModel.Previous}"
                Content="&#xE76B;"
                CornerRadius="16"
                FontFamily="Segoe Fluent Icons"
                FontSize="14"
                IsEnabled="{x:Bind ViewModel.CanSwitch, Mode=OneWay}" />
            <TextBlock
                MinWidth="30"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Style="{StaticResource CaptionTextBlockStyle}"
                Text="{x:Bind ViewModel.DevicePositionText, Mode=OneWay}"
                TextAlignment="Center" />
            <Button
                x:Uid="NextButton"
                Width="32"
                Height="32"
                Padding="0"
                Click="{x:Bind ViewModel.Next}"
                Content="&#xE76C;"
                CornerRadius="16"
                FontFamily="Segoe Fluent Icons"
                FontSize="14"
                IsEnabled="{x:Bind ViewModel.CanSwitch, Mode=OneWay}" />
        </StackPanel>
    </Grid>
</UserControl>

<UserControl
    x:Class="Glance.AudioSwitcher.WinUI.AudioSwitcherExpandedView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:AudioSwitcher="using:Glance.AudioSwitcher"
    xmlns:Controls="using:Elysium.UI.Controls.WinUI">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Themes/AudioSwitcher.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <Style
                x:Key="AudioSwitcherActionButtonStyle"
                BasedOn="{StaticResource SubtleButtonStyle}"
                TargetType="Button">
                <Setter Property="Width" Value="32" />
                <Setter Property="Height" Value="32" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="CornerRadius" Value="{ThemeResource ControlCornerRadius}" />
                <Setter Property="FontFamily" Value="Segoe Fluent Icons" />
                <Setter Property="FontSize" Value="14" />
            </Style>
            <DataTemplate x:Key="AudioOutputItemTemplate" x:DataType="AudioSwitcher:AudioOutputDeviceItemViewModel">
                <Grid Margin="2,0,0,0" ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Center" Spacing="1">
                        <Controls:MarqueeTextBlock
                            Height="20"
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                            Text="{x:Bind Name, Mode=OneWay}"
                            ToolTipService.ToolTip="{x:Bind Name, Mode=OneWay}" />
                        <TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Style="{StaticResource CaptionTextBlockStyle}"
                            Text="{x:Bind VolumeText, Mode=OneWay}" />
                    </StackPanel>
                    <Button
                        x:Uid="ToggleMuteButton"
                        Grid.Column="1"
                        Click="{x:Bind ToggleMute}"
                        Content="{x:Bind ToggleGlyph, Mode=OneWay}"
                        Style="{StaticResource AudioSwitcherActionButtonStyle}" />
                </Grid>
            </DataTemplate>
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid Padding="20,12,20,26" ColumnSpacing="18">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid
            x:Name="StatusIndicator"
            Width="36"
            Height="36"
            VerticalAlignment="Center">
            <FontIcon
                Width="30"
                Height="30"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontFamily="Segoe Fluent Icons"
                FontSize="30"
                Foreground="{ThemeResource GlanceAudioSwitcherIconBrush}"
                Glyph="&#xE767;" />
        </Grid>
        <Grid
            Grid.Column="1"
            Height="58"
            VerticalAlignment="Center"
            RowSpacing="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <TextBlock
                FontWeight="SemiBold"
                Foreground="{ThemeResource GlanceAudioSwitcherIconBrush}"
                Style="{StaticResource CaptionTextBlockStyle}"
                Text="{x:Bind ToUpper(Title)}" />
            <TextBlock
                Grid.Row="1"
                VerticalAlignment="Center"
                Style="{StaticResource BodyStrongTextBlockStyle}"
                Text="{x:Bind ViewModel.CurrentDeviceName, Mode=OneWay}"
                TextTrimming="CharacterEllipsis"
                TextWrapping="NoWrap"
                Visibility="{x:Bind WhenEmpty(ViewModel.HasDevices), Mode=OneWay}" />
            <Controls:CompactFlipView
                Grid.Row="1"
                Margin="-22,0,0,0"
                Background="Transparent"
                ItemTemplate="{StaticResource AudioOutputItemTemplate}"
                ItemsSource="{x:Bind ViewModel.Devices}"
                SelectedItem="{x:Bind ViewModel.SelectedDevice, Mode=TwoWay}"
                Visibility="{x:Bind WhenPopulated(ViewModel.HasDevices), Mode=OneWay}" />
        </Grid>
    </Grid>
</UserControl>

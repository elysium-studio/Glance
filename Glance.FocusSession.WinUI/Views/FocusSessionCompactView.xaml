<UserControl
    x:Class="Glance.FocusSession.WinUI.FocusSessionCompactView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <ResourceDictionary Source="../Themes/FocusSession.xaml" />
    </UserControl.Resources>
    <Grid x:Name="LayoutRoot" Padding="8,0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid
            x:Name="StatusIndicator"
            Width="26"
            Height="26">
            <FontIcon
                Width="24"
                Height="24"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontFamily="Segoe Fluent Icons"
                FontSize="24"
                Foreground="{ThemeResource GlanceFocusSessionIconBrush}"
                Glyph="&#xE708;" />
        </Grid>
        <Grid
            Grid.Column="1"
            Margin="8,0,0,0"
            VerticalAlignment="Center">
            <TextBlock
                HorizontalAlignment="Left"
                FontWeight="SemiBold"
                Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                Style="{StaticResource BodyLargeTextBlockStyle}"
                Text="{x:Bind ViewModel.RemainingText, Mode=OneWay}" />
            <ProgressBar
                Height="2"
                Margin="0,25,0,0"
                Background="{ThemeResource GlanceFocusSessionTrackBrush}"
                Foreground="{ThemeResource GlanceFocusSessionIconBrush}"
                Maximum="100"
                Value="{x:Bind ViewModel.Progress, Mode=OneWay}" />
        </Grid>
    </Grid>
</UserControl>

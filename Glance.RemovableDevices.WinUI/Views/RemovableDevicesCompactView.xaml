<UserControl
    x:Class="Glance.RemovableDevices.WinUI.RemovableDevicesCompactView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <ResourceDictionary Source="../Themes/RemovableDevices.xaml" />
    </UserControl.Resources>
    <Grid Padding="8,0" ColumnSpacing="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid
            x:Name="StatusIndicator"
            Width="30"
            Height="30">
            <FontIcon
                Width="24"
                Height="24"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontFamily="Segoe Fluent Icons"
                FontSize="24"
                Foreground="{ThemeResource GlanceRemovableDevicesIconBrush}"
                Glyph="&#xE88E;" />
        </Grid>
        <TextBlock
            Grid.Column="1"
            VerticalAlignment="Center"
            MaxLines="1"
            Style="{StaticResource BodyStrongTextBlockStyle}"
            Text="{x:Bind ViewModel.CompactStatusText, Mode=OneWay}"
            TextTrimming="CharacterEllipsis"
            TextWrapping="NoWrap" />
    </Grid>
</UserControl>

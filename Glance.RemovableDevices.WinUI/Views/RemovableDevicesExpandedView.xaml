<UserControl
    x:Class="Glance.RemovableDevices.WinUI.RemovableDevicesExpandedView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Controls="using:Elysium.UI.Controls.WinUI"
    xmlns:RemovableDevices="using:Glance.RemovableDevices">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Themes/RemovableDevices.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <Style
                x:Key="RemovableDeviceActionButtonStyle"
                BasedOn="{StaticResource SubtleButtonStyle}"
                TargetType="Button">
                <Setter Property="Width" Value="32" />
                <Setter Property="Height" Value="32" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="CornerRadius" Value="{ThemeResource ControlCornerRadius}" />
                <Setter Property="FontFamily" Value="Segoe Fluent Icons" />
                <Setter Property="FontSize" Value="14" />
            </Style>
            <DataTemplate x:Key="RemovableDeviceItemTemplate" x:DataType="RemovableDevices:RemovableDeviceItemViewModel">
                <Grid Margin="2,0,0,0" ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Grid VerticalAlignment="Center" RowSpacing="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock
                            MaxLines="1"
                            Style="{StaticResource BodyStrongTextBlockStyle}"
                            Text="{x:Bind DisplayName, Mode=OneWay}"
                            TextTrimming="CharacterEllipsis"
                            TextWrapping="NoWrap"
                            ToolTipService.ToolTip="{x:Bind DisplayName, Mode=OneWay}" />
                        <Grid Grid.Row="1" ColumnSpacing="5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Style="{StaticResource CaptionTextBlockStyle}"
                                Text="{x:Bind DriveLetter, Mode=OneWay}" />
                            <TextBlock
                                Grid.Column="1"
                                Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                Style="{StaticResource CaptionTextBlockStyle}"
                                Text="&#x2022;" />
                            <TextBlock
                                Grid.Column="2"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Style="{StaticResource CaptionTextBlockStyle}"
                                Text="{x:Bind Detail, Mode=OneWay}"
                                TextTrimming="CharacterEllipsis"
                                TextWrapping="NoWrap" />
                        </Grid>
                        <ProgressBar
                            Grid.Row="2"
                            Height="3"
                            Margin="0,2,0,0"
                            VerticalAlignment="Center"
                            Background="{ThemeResource GlanceRemovableDevicesTrackBrush}"
                            Foreground="{ThemeResource GlanceRemovableDevicesIconBrush}"
                            IsIndeterminate="False"
                            Maximum="100"
                            Value="{x:Bind UsagePercent, Mode=OneWay}" />
                    </Grid>
                    <StackPanel
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        Orientation="Horizontal"
                        Spacing="2">
                        <Button
                            x:Uid="OpenButton"
                            Click="{x:Bind Open}"
                            Content="&#xE838;"
                            Style="{StaticResource RemovableDeviceActionButtonStyle}" />
                        <Button
                            x:Uid="EjectButton"
                            Click="{x:Bind Eject}"
                            Content="&#xF847;"
                            IsEnabled="{x:Bind CanEject, Mode=OneWay}"
                            Style="{StaticResource RemovableDeviceActionButtonStyle}" />
                    </StackPanel>
                </Grid>
            </DataTemplate>
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid Padding="20,12,20,26">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid
            x:Name="StatusIndicator"
            Width="36"
            Height="36"
            VerticalAlignment="Center">
            <FontIcon
                Width="30"
                Height="30"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontFamily="Segoe Fluent Icons"
                FontSize="30"
                Foreground="{ThemeResource GlanceRemovableDevicesIconBrush}"
                Glyph="&#xE88E;" />
        </Grid>
        <Grid
            Grid.Column="1"
            Height="58"
            Margin="18,0,0,0"
            VerticalAlignment="Center"
            RowSpacing="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="14" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <TextBlock
                FontWeight="SemiBold"
                Foreground="{ThemeResource GlanceRemovableDevicesIconBrush}"
                Style="{StaticResource CaptionTextBlockStyle}"
                Text="{x:Bind ToUpper(Title)}" />
            <TextBlock
                x:Uid="EmptyMessage"
                Grid.Row="1"
                Style="{StaticResource BodyStrongTextBlockStyle}"
                TextTrimming="CharacterEllipsis"
                TextWrapping="NoWrap"
                Visibility="{x:Bind WhenEmpty(ViewModel.HasDevices), Mode=OneWay}" />
            <Controls:CompactFlipView
                Grid.Row="1"
                Margin="-22,0,0,0"
                Background="Transparent"
                ItemTemplate="{StaticResource RemovableDeviceItemTemplate}"
                ItemsSource="{x:Bind ViewModel.Devices}"
                SelectedItem="{x:Bind ViewModel.SelectedDevice, Mode=TwoWay}"
                Visibility="{x:Bind WhenPopulated(ViewModel.HasDevices), Mode=OneWay}" />
        </Grid>
    </Grid>
</UserControl>

<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="Glance.VoiceNotes.WinUI.RecentRecordingLimitSettingView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:CommunityToolkit="using:CommunityToolkit.WinUI.Controls"
    Loaded="{x:Bind ViewModel.Activate}"
    Unloaded="{x:Bind ViewModel.Deactivate}">
    <CommunityToolkit:SettingsCard x:Uid="RecentRecordingLimitSettingCard">
        <NumberBox Minimum="1" Maximum="10" SmallChange="1" SpinButtonPlacementMode="Compact" Value="{x:Bind ViewModel.Value, Mode=TwoWay}" />
    </CommunityToolkit:SettingsCard>
</UserControl>

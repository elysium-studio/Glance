<UserControl
    x:Class="Glance.VoiceNotes.WinUI.VoiceWaveform"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Loaded="{x:Bind HandleLoaded}"
    Unloaded="{x:Bind HandleUnloaded}">
    <UserControl.Resources>
        <ResourceDictionary Source="../Themes/VoiceNotes.xaml" />
    </UserControl.Resources>
    <Grid IsHitTestVisible="False">
        <Border
            Height="1"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Center"
            Background="{ThemeResource GlanceVoiceNotesTrackBrush}" />
        <StackPanel
            x:Name="WaveformPanel"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Orientation="Horizontal"
            Spacing="2" />
    </Grid>
</UserControl>

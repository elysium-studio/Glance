<UserControl
    x:Class="Glance.Media.WinUI.MediaExpandedView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <ResourceDictionary Source="../Themes/Media.xaml" />
    </UserControl.Resources>
    <Grid Padding="18,12,18,26" ColumnSpacing="14">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <Border
            x:Name="ArtworkContainer"
            Width="68"
            Height="68"
            Background="{ThemeResource ControlFillColorSecondaryBrush}"
            CornerRadius="{StaticResource OverlayCornerRadius}">
            <Grid>
                <FontIcon
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontSize="26"
                    Foreground="{ThemeResource GlanceMediaIconBrush}"
                    Glyph="&#xE8D6;" />
                <Image Source="{x:Bind ToImageSource(ViewModel.Artwork), Mode=OneWay}" Stretch="UniformToFill" />
            </Grid>
        </Border>
        <StackPanel
            Grid.Column="1"
            VerticalAlignment="Center"
            Spacing="2">
            <TextBlock
                FontSize="11"
                FontWeight="SemiBold"
                Foreground="{ThemeResource GlanceMediaIconBrush}"
                Text="{x:Bind ToUpper(ViewModel.Source), Mode=OneWay}" />
            <TextBlock
                FontWeight="SemiBold"
                MaxLines="1"
                Style="{StaticResource BodyLargeTextBlockStyle}"
                Text="{x:Bind ViewModel.Title, Mode=OneWay}"
                TextTrimming="CharacterEllipsis"
                TextWrapping="NoWrap" />
            <TextBlock
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Style="{StaticResource CaptionTextBlockStyle}"
                Text="{x:Bind ViewModel.Artist, Mode=OneWay}"
                TextTrimming="CharacterEllipsis"
                TextWrapping="NoWrap" />
        </StackPanel>
        <StackPanel
            Grid.Column="2"
            VerticalAlignment="Center"
            Orientation="Horizontal"
            Spacing="5">
            <Button
                Width="32"
                Height="32"
                Padding="0"
                Click="{x:Bind ViewModel.Previous}"
                Content="&#xE622;"
                CornerRadius="16"
                FontFamily="Segoe Fluent Icons"
                FontSize="14"
                ToolTipService.ToolTip="Previous" />
            <Button
                Width="38"
                Height="38"
                Padding="0"
                Click="{x:Bind ViewModel.TogglePlayback}"
                Content="{x:Bind ViewModel.PlayPauseGlyph, Mode=OneWay}"
                CornerRadius="19"
                FontFamily="Segoe Fluent Icons"
                FontSize="18"
                Style="{StaticResource AccentButtonStyle}"
                ToolTipService.ToolTip="Play or pause" />
            <Button
                Width="32"
                Height="32"
                Padding="0"
                Click="{x:Bind ViewModel.Next}"
                Content="&#xE623;"
                CornerRadius="16"
                FontFamily="Segoe Fluent Icons"
                FontSize="14"
                ToolTipService.ToolTip="Next" />
        </StackPanel>
    </Grid>
</UserControl>

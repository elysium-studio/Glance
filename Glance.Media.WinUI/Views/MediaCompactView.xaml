<UserControl
    x:Class="Glance.Media.WinUI.MediaCompactView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Padding="10,0" ColumnSpacing="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <Border
            x:Name="ArtworkContainer"
            Width="30"
            Height="30"
            Background="{ThemeResource ControlFillColorSecondaryBrush}"
            CornerRadius="7">
            <Grid>
                <FontIcon
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    FontSize="14"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Glyph="&#xE8D6;" />
                <Image Source="{Binding Artwork}" Stretch="UniformToFill" />
            </Grid>
        </Border>
        <StackPanel Grid.Column="1" VerticalAlignment="Center">
            <TextBlock
                FontSize="13"
                FontWeight="SemiBold"
                Text="{Binding Title}"
                TextTrimming="CharacterEllipsis" />
            <TextBlock
                FontSize="11"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="{Binding Artist}"
                TextTrimming="CharacterEllipsis" />
        </StackPanel>
        <Button
            Grid.Column="2"
            Width="26"
            Height="26"
            Padding="0"
            VerticalAlignment="Center"
            Command="{Binding TogglePlaybackCommand}"
            CornerRadius="13"
            FontFamily="Segoe Fluent Icons"
            FontSize="14"
            Content="{Binding PlayPauseGlyph}"
            Style="{StaticResource AccentButtonStyle}" />
    </Grid>
</UserControl>

<UserControl
    x:Class="Glance.Media.WinUI.MediaAudioVisualizer"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Loaded="{x:Bind HandleLoaded}"
    Unloaded="{x:Bind HandleUnloaded}">
    <UserControl.Resources>
        <ResourceDictionary Source="../Themes/Media.xaml" />
    </UserControl.Resources>
    <StackPanel
        HorizontalAlignment="Center"
        VerticalAlignment="Center"
        IsHitTestVisible="False"
        Orientation="Horizontal"
        Spacing="2">
        <Border x:Name="BarOne" Width="3" Height="16" Background="{ThemeResource GlanceMediaIconBrush}" CornerRadius="2" />
        <Border x:Name="BarTwo" Width="3" Height="16" Background="{ThemeResource GlanceMediaIconBrush}" CornerRadius="2" />
        <Border x:Name="BarThree" Width="3" Height="16" Background="{ThemeResource GlanceMediaIconBrush}" CornerRadius="2" />
        <Border x:Name="BarFour" Width="3" Height="16" Background="{ThemeResource GlanceMediaIconBrush}" CornerRadius="2" />
        <Border x:Name="BarFive" Width="3" Height="16" Background="{ThemeResource GlanceMediaIconBrush}" CornerRadius="2" />
    </StackPanel>
</UserControl>

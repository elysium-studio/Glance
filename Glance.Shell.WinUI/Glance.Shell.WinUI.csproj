<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows10.0.22000.0</TargetFramework>
    <TargetPlatformMinVersion>10.0.17763.0</TargetPlatformMinVersion>
    <RootNamespace>Glance.Shell.WinUI</RootNamespace>
    <AssemblyName>Glance</AssemblyName>
    <AssemblyTitle>Glance</AssemblyTitle>
    <ApplicationIcon>Assets\Glance.ico</ApplicationIcon>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <Platforms>x64</Platforms>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <UseWinUI>true</UseWinUI>
    <EnableMsixTooling>false</EnableMsixTooling>
    <WindowsPackageType>None</WindowsPackageType>
    <Nullable>enable</Nullable>
    <EnablePreviewFeatures>true</EnablePreviewFeatures>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <WindowsAppSDKSelfContained Condition="'$(Configuration)' == 'Release'">true</WindowsAppSDKSelfContained>
    <DefineConstants>DISABLE_XAML_GENERATED_MAIN</DefineConstants>
    <StartupObject>Glance.Shell.WinUI.Start</StartupObject>
    <DefaultLanguage>en</DefaultLanguage>
  </PropertyGroup>
  <ItemGroup>
    <Content Include="Assets\**\*">
      <CopyToPublishDirectory>PreserveNewest</CopyToPublishDirectory>
    </Content>
  </ItemGroup>
  <ItemGroup>
    <PRIResource Include="Strings\**\*.resw" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="CommunityToolkit.WinUI.Controls.SettingsControls" Version="8.3.260402-preview2" />
    <PackageReference Include="Elysium.Application" Version="$(ElysiumVersion)" />
    <PackageReference Include="Elysium.Application.Abstractions" Version="$(ElysiumVersion)" />
    <PackageReference Include="Elysium.Application.DependencyInjection" Version="$(ElysiumVersion)" />
    <PackageReference Include="Elysium.Platform.Abstractions" Version="$(ElysiumVersion)" />
    <PackageReference Include="Elysium.Platform.Windows" Version="$(ElysiumVersion)" />
    <PackageReference Include="Elysium.Presentation" Version="$(ElysiumVersion)" />
    <PackageReference Include="Elysium.Presentation.Abstractions" Version="$(ElysiumVersion)" />
    <PackageReference Include="Elysium.Presentation.DependencyInjection" Version="$(ElysiumVersion)" />
    <PackageReference Include="Elysium.UI.Controls.WinUI" Version="$(ElysiumVersion)" />
    <PackageReference Include="Elysium.UI.WinUI" Version="$(ElysiumVersion)" />
    <PackageReference Include="Microsoft.Extensions.Hosting" Version="10.0.9" />
    <PackageReference Include="Microsoft.Windows.SDK.BuildTools" Version="10.0.28000.2270" />
    <PackageReference Include="Microsoft.WindowsAppSDK" Version="2.2.0" />
    <PackageReference Include="Microsoft.WindowsAppSDK.Runtime" Version="2.2.0" GeneratePathProperty="true" PrivateAssets="all" />
    <PackageReference Include="Velopack" Version="1.2.0" />
    <PackageReference Include="WinUIEx" Version="2.9.1" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\Glance.Application.Abstractions\Glance.Application.Abstractions.csproj" />
    <ProjectReference Include="..\Glance.AudioSwitcher.WinUI\Glance.AudioSwitcher.WinUI.csproj" />
    <ProjectReference Include="..\Glance.Clipboard.WinUI\Glance.Clipboard.WinUI.csproj" />
    <ProjectReference Include="..\Glance.ColorPicker.WinUI\Glance.ColorPicker.WinUI.csproj" />
    <ProjectReference Include="..\Glance.DevicePresence.WinUI\Glance.DevicePresence.WinUI.csproj" />
    <ProjectReference Include="..\Glance.DropShelf.WinUI\Glance.DropShelf.WinUI.csproj" />
    <ProjectReference Include="..\Glance.FocusSession.WinUI\Glance.FocusSession.WinUI.csproj" />
    <ProjectReference Include="..\Glance.Media.WinUI\Glance.Media.WinUI.csproj" />
    <ProjectReference Include="..\Glance.Power.WinUI\Glance.Power.WinUI.csproj" />
    <ProjectReference Include="..\Glance.PrivacyControls.WinUI\Glance.PrivacyControls.WinUI.csproj" />
    <ProjectReference Include="..\Glance.RemovableDevices.WinUI\Glance.RemovableDevices.WinUI.csproj" />
    <ProjectReference Include="..\Glance.ScreenCapture.WinUI\Glance.ScreenCapture.WinUI.csproj" />
    <ProjectReference Include="..\Glance.Shell\Glance.Shell.csproj" />
    <ProjectReference Include="..\Glance.Stopwatch.WinUI\Glance.Stopwatch.WinUI.csproj" />
    <ProjectReference Include="..\Glance.SystemMonitor.WinUI\Glance.SystemMonitor.WinUI.csproj" />
    <ProjectReference Include="..\Glance.Timer.WinUI\Glance.Timer.WinUI.csproj" />
    <ProjectReference Include="..\Glance.UI.WinUI\Glance.UI.WinUI.csproj" />
    <ProjectReference Include="..\Glance.VoiceNotes.WinUI\Glance.VoiceNotes.WinUI.csproj" />
  </ItemGroup>
  <Target Name="CopyPriAndXbfToPublish" AfterTargets="Publish">
    <ItemGroup>
      <PriFiles Include="$(OutDir)*.pri" />
      <XbfFiles Include="$(OutDir)*.xbf" />
    </ItemGroup>
    <Copy SourceFiles="@(PriFiles)" DestinationFolder="$(PublishDir)" />
    <Copy SourceFiles="@(XbfFiles)" DestinationFolder="$(PublishDir)" />
  </Target>
  <UsingTask TaskName="ExtractWindowsAppRuntimeInsightsResource" TaskFactory="RoslynCodeTaskFactory" AssemblyFile="$(MSBuildToolsPath)\Microsoft.Build.Tasks.Core.dll">
    <ParameterGroup>
      <ArchivePath ParameterType="System.String" Required="true" />
      <OutputPath ParameterType="System.String" Required="true" />
    </ParameterGroup>
    <Task>
      <Using Namespace="System.IO" />
      <Using Namespace="System.IO.Compression" />
      <Code Type="Fragment" Language="cs"><![CDATA[
        const string entryName = "Microsoft.WindowsAppRuntime.Insights.Resource.dll";
        using (ZipArchive archive = ZipFile.OpenRead(ArchivePath))
        {
          ZipArchiveEntry entry = archive.GetEntry(entryName);
          if (entry == null)
          {
            Log.LogError($"{entryName} was not found in {ArchivePath}.");
          }
          else
          {
            Directory.CreateDirectory(Path.GetDirectoryName(OutputPath) ?? ".");
            entry.ExtractToFile(OutputPath, true);
          }
        }
      ]]></Code>
    </Task>
  </UsingTask>
  <Target Name="CopyWindowsAppRuntimeInsightsResourceToPublish" AfterTargets="Publish" Condition="'$(WindowsAppSDKSelfContained)' == 'true'">
    <PropertyGroup>
      <WindowsAppRuntimeFrameworkMsix>$(PkgMicrosoft_WindowsAppSDK_Runtime)\tools\MSIX\win10-x64\Microsoft.WindowsAppRuntime.2.msix</WindowsAppRuntimeFrameworkMsix>
    </PropertyGroup>
    <Error Condition="!Exists('$(WindowsAppRuntimeFrameworkMsix)')" Text="Windows App Runtime framework package was not found at $(WindowsAppRuntimeFrameworkMsix)." />
    <ExtractWindowsAppRuntimeInsightsResource ArchivePath="$(WindowsAppRuntimeFrameworkMsix)" OutputPath="$(PublishDir)Microsoft.WindowsAppRuntime.Insights.Resource.dll" />
  </Target>
</Project>

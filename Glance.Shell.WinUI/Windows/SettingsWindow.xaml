<Window
    x:Class="Glance.Shell.WinUI.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Shell="using:Glance.Shell"
    xmlns:Toolkit="using:CommunityToolkit.WinUI.Controls"
    xmlns:WinUI="using:Elysium.UI.WinUI">
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>
    <Grid
        x:Name="Root"
        DataContext="{WinUI:ViewModel Key=SettingsWindow}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <TitleBar
            x:Name="AppTitleBar"
            Subtitle="Preferences"
            Title="Glance">
            <TitleBar.IconSource>
                <FontIconSource Glyph="&#xE713;" />
            </TitleBar.IconSource>
        </TitleBar>
        <NavigationView
            Grid.Row="1"
            Margin="0,8,0,0"
            IsBackButtonVisible="Collapsed"
            IsPaneToggleButtonVisible="False"
            IsSettingsVisible="False"
            PaneDisplayMode="Left">
            <NavigationView.Resources>
                <SolidColorBrush x:Key="NavigationViewContentBackground" Color="Transparent" />
                <SolidColorBrush x:Key="NavigationViewContentGridBorderBrush" Color="Transparent" />
                <Thickness x:Key="NavigationViewContentGridBorderThickness">0</Thickness>
            </NavigationView.Resources>
            <NavigationView.MenuItems>
                <NavigationViewItem Content="Modules" IsSelected="True">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE74C;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <StackPanel Margin="36,8,36,20" Spacing="4">
                    <TextBlock
                        FontFamily="Segoe UI Variable Display"
                        FontSize="28"
                        FontWeight="SemiBold"
                        Text="Modules" />
                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="Choose which modules appear in Glance and drag them into your preferred order." />
                </StackPanel>
                <ListView
                    x:Name="ModulesList"
                    Grid.Row="1"
                    Margin="36,0,36,36"
                    AllowDrop="True"
                    CanDragItems="True"
                    CanReorderItems="True"
                    DragItemsCompleted="HandleDragItemsCompleted"
                    ItemsSource="{x:Bind ViewModel.Modules, Mode=OneWay}"
                    ReorderMode="Enabled"
                    SelectionMode="None">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0,0,0,4" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="Shell:ModuleSettingsItemViewModel">
                            <Toolkit:SettingsCard
                                Description="{x:Bind Description}"
                                Header="{x:Bind DisplayName}"
                                IsClickEnabled="False">
                                <ToggleSwitch
                                    AutomationProperties.Name="{x:Bind DisplayName}"
                                    IsOn="{x:Bind IsEnabled, Mode=TwoWay}" />
                            </Toolkit:SettingsCard>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </NavigationView>
    </Grid>
</Window>

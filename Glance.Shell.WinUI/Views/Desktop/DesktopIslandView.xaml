<Controls:DesktopIsland
    x:Class="Glance.Shell.WinUI.DesktopIslandView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Controls="using:Elysium.UI.Controls.WinUI"
    xmlns:WinUI="using:Elysium.UI.WinUI"
    CompactWidth="220"
    DataContext="{WinUI:ViewModel Key=DesktopIslandView}"
    IsExpanded="{x:Bind ViewModel.IsExpanded, Mode=TwoWay}"
    IsOpen="{x:Bind ViewModel.IsOpen, Mode=TwoWay}"
    IsTabStop="False"
    PointerWheelChanged="HandlePointerWheelChanged">
    <Controls:DesktopIsland.CompactContent>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="50" />
            </Grid.ColumnDefinitions>
            <ContentPresenter
                x:Name="CompactPresenter"
                Content="{x:Bind ViewModel.SelectedComponent.CompactContent, Mode=OneWay}" />
            <PipsPager
                Grid.Column="1"
                Width="48"
                Height="24"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                MaxVisiblePips="3"
                NextButtonVisibility="Collapsed"
                NumberOfPages="{x:Bind ViewModel.ComponentCount}"
                PreviousButtonVisibility="Collapsed"
                SelectedPageIndex="{x:Bind ViewModel.SelectedIndex, Mode=TwoWay}" />
        </Grid>
    </Controls:DesktopIsland.CompactContent>
    <Controls:DesktopIsland.ExpandedContent>
        <Grid>
            <ContentPresenter
                x:Name="ExpandedPresenter"
                Content="{x:Bind ViewModel.SelectedComponent.ExpandedContent, Mode=OneWay}" />
            <StackPanel
                Margin="0,0,0,4"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Orientation="Horizontal"
                Spacing="6">
                <PipsPager
                    Height="24"
                    IsEnabled="{x:Bind ViewModel.HasMultipleComponents}"
                    MaxVisiblePips="5"
                    NextButtonVisibility="VisibleOnPointerOver"
                    NumberOfPages="{x:Bind ViewModel.ComponentCount}"
                    PreviousButtonVisibility="VisibleOnPointerOver"
                    SelectedPageIndex="{x:Bind ViewModel.SelectedIndex, Mode=TwoWay}" />
                <Border
                    Width="1"
                    Height="12"
                    VerticalAlignment="Center"
                    Background="{ThemeResource DividerStrokeColorDefaultBrush}" />
                <Button
                    Width="24"
                    Height="24"
                    Padding="0"
                    VerticalAlignment="Center"
                    Background="Transparent"
                    BorderThickness="0"
                    Command="{x:Bind ViewModel.OpenSettingsCommand}"
                    Content="&#xE713;"
                    CornerRadius="6"
                    FontFamily="Segoe Fluent Icons"
                    FontSize="12"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    ToolTipService.ToolTip="Settings" />
            </StackPanel>
        </Grid>
    </Controls:DesktopIsland.ExpandedContent>
</Controls:DesktopIsland>

<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="Glance.Shell.WinUI.AutoHideView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:CommunityToolkit="using:CommunityToolkit.WinUI.Controls"
    Loaded="{x:Bind ViewModel.Activate}"
    Unloaded="{x:Bind ViewModel.Deactivate}">
    <CommunityToolkit:SettingsCard x:Uid="AutoHideCard">
        <ToggleSwitch
            x:Uid="BooleanToggle"
            IsOn="{x:Bind ViewModel.Value, Mode=TwoWay}" />
    </CommunityToolkit:SettingsCard>
</UserControl>

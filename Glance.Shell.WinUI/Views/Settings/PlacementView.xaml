<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="Glance.Shell.WinUI.PlacementView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:CommunityToolkit="using:CommunityToolkit.WinUI.Controls"
    Loaded="{x:Bind ViewModel.Activate}"
    Unloaded="{x:Bind ViewModel.Deactivate}">
    <CommunityToolkit:SettingsCard x:Uid="GlancePlacementCard">
        <ComboBox SelectedIndex="{x:Bind SelectedPlacementIndex, Mode=TwoWay}">
            <ComboBoxItem x:Uid="GlancePlacementTopOption">
                <ComboBoxItem.Tag>
                    <x:Int32>0</x:Int32>
                </ComboBoxItem.Tag>
            </ComboBoxItem>
            <ComboBoxItem x:Uid="GlancePlacementBottomOption">
                <ComboBoxItem.Tag>
                    <x:Int32>1</x:Int32>
                </ComboBoxItem.Tag>
            </ComboBoxItem>
        </ComboBox>
    </CommunityToolkit:SettingsCard>
</UserControl>

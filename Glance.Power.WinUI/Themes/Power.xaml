<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Default">
            <SolidColorBrush x:Key="GlancePowerIconBrush" Color="#F6C75C" />
            <SolidColorBrush x:Key="AccentButtonBackground" Color="#FFF6C75C" />
            <SolidColorBrush x:Key="AccentButtonBackgroundPointerOver" Color="#E6F6C75C" />
            <SolidColorBrush x:Key="AccentButtonBackgroundPressed" Color="#CCF6C75C" />
            <SolidColorBrush x:Key="AccentButtonBackgroundDisabled" Color="#28FFFFFF" />
        </ResourceDictionary>
        <ResourceDictionary x:Key="Light">
            <SolidColorBrush x:Key="GlancePowerIconBrush" Color="#7A5200" />
            <SolidColorBrush x:Key="AccentButtonBackground" Color="#FF7A5200" />
            <SolidColorBrush x:Key="AccentButtonBackgroundPointerOver" Color="#E67A5200" />
            <SolidColorBrush x:Key="AccentButtonBackgroundPressed" Color="#CC7A5200" />
            <SolidColorBrush x:Key="AccentButtonBackgroundDisabled" Color="#28FFFFFF" />
        </ResourceDictionary>
        <ResourceDictionary x:Key="HighContrast">
            <StaticResource x:Key="GlancePowerIconBrush" ResourceKey="SystemColorWindowTextColorBrush" />
            <StaticResource x:Key="AccentButtonBackground" ResourceKey="SystemColorHighlightColorBrush" />
            <StaticResource x:Key="AccentButtonBackgroundPointerOver" ResourceKey="SystemColorHighlightColorBrush" />
            <StaticResource x:Key="AccentButtonBackgroundPressed" ResourceKey="SystemColorHighlightColorBrush" />
            <StaticResource x:Key="AccentButtonBackgroundDisabled" ResourceKey="SystemColorButtonFaceColorBrush" />
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>
</ResourceDictionary>

<UserControl
    x:Class="Glance.Power.WinUI.PowerExpandedView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Padding="18,12,18,26" ColumnSpacing="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <Grid
            x:Name="StatusIndicator"
            Width="44"
            Height="36"
            VerticalAlignment="Center">
            <Grid Width="40" Height="22">
                <Border
                    Width="35"
                    Height="22"
                    HorizontalAlignment="Left"
                    BorderBrush="{ThemeResource GlancePowerIconBrush}"
                    BorderThickness="2"
                    CornerRadius="5">
                    <ProgressBar
                        Height="12"
                        Margin="3"
                        Background="Transparent"
                        Foreground="{ThemeResource GlancePowerIconBrush}"
                        Maximum="100"
                        Value="{Binding ChargePercent}" />
                </Border>
                <Border
                    Width="4"
                    Height="10"
                    HorizontalAlignment="Right"
                    Background="{ThemeResource GlancePowerIconBrush}"
                    CornerRadius="0,2,2,0" />
            </Grid>
        </Grid>
        <StackPanel
            Grid.Column="1"
            VerticalAlignment="Center"
            Spacing="1">
            <TextBlock
                FontSize="10"
                FontWeight="SemiBold"
                Foreground="{ThemeResource GlancePowerIconBrush}"
                Text="POWER" />
            <TextBlock
                FontSize="27"
                FontWeight="SemiBold"
                Text="{Binding ChargeText}" />
        </StackPanel>
        <Border
            Grid.Column="2"
            MinWidth="164"
            Padding="12,7"
            VerticalAlignment="Center"
            Background="{ThemeResource ControlFillColorSecondaryBrush}"
            CornerRadius="10">
            <StackPanel Spacing="2">
                <TextBlock
                    FontSize="12"
                    FontWeight="SemiBold"
                    Text="{Binding StatusText}" />
                <TextBlock
                    FontSize="10"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="{Binding DetailText}"
                    TextTrimming="CharacterEllipsis" />
                <TextBlock
                    FontSize="10"
                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                    Text="{Binding PowerSourceText}" />
            </StackPanel>
        </Border>
    </Grid>
</UserControl>

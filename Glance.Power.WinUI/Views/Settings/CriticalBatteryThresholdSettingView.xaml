<?xml version="1.0" encoding="utf-8" ?>
<UserControl
    x:Class="Glance.Power.WinUI.CriticalBatteryThresholdSettingView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:CommunityToolkit="using:CommunityToolkit.WinUI.Controls"
    Loaded="{x:Bind ViewModel.Activate}"
    Unloaded="{x:Bind ViewModel.Deactivate}">
    <CommunityToolkit:SettingsCard x:Uid="CriticalBatteryThresholdSettingCard">
        <NumberBox Minimum="5" Maximum="20" SmallChange="5" SpinButtonPlacementMode="Compact" Value="{x:Bind ViewModel.Value, Mode=TwoWay}" />
    </CommunityToolkit:SettingsCard>
</UserControl>

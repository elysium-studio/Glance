<UserControl
    x:Class="Glance.Clipboard.WinUI.ClipboardExpandedView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Clipboard="using:Glance.Clipboard">
    <Grid Padding="16,10,16,26" ColumnSpacing="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="140" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid
            x:Name="StatusIndicator"
            Width="42"
            Height="42"
            VerticalAlignment="Center">
            <Viewbox
                Width="30"
                Height="30"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
                <Canvas Width="14" Height="14">
                    <Path
                        Data="M 5,2.5 L 3.5,2.5 C 2.7,2.5 2,3.2 2,4 L 2,11.5 C 2,12.3 2.7,13 3.5,13 L 10.5,13 C 11.3,13 12,12.3 12,11.5 L 12,4 C 12,3.2 11.3,2.5 10.5,2.5 L 9,2.5 M 5,1 L 9,1 L 9,4 L 5,4 Z"
                        Stroke="{ThemeResource GlanceClipboardIconBrush}"
                        StrokeEndLineCap="Round"
                        StrokeLineJoin="Round"
                        StrokeStartLineCap="Round"
                        StrokeThickness="0.9" />
                </Canvas>
            </Viewbox>
        </Grid>
        <StackPanel
            Grid.Column="1"
            VerticalAlignment="Center"
            Spacing="1">
            <TextBlock
                FontSize="10"
                FontWeight="SemiBold"
                Foreground="{ThemeResource GlanceClipboardIconBrush}"
                Text="CLIPBOARD" />
            <TextBlock
                FontSize="16"
                FontWeight="SemiBold"
                MaxLines="2"
                Text="{Binding LatestPreview}"
                TextTrimming="CharacterEllipsis" />
            <TextBlock
                FontSize="10"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="{Binding LatestKind}" />
        </StackPanel>
        <StackPanel
            Grid.Column="2"
            VerticalAlignment="Center"
            Spacing="2">
            <TextBlock
                FontSize="9"
                Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                MaxLines="1"
                Text="{Binding HistoryStatus}"
                TextTrimming="CharacterEllipsis" />
            <ListView
                Height="54"
                IsItemClickEnabled="True"
                ItemClick="HandleItemClick"
                ItemsSource="{Binding ShelfItems}"
                SelectionMode="None"
                ScrollViewer.HorizontalScrollMode="Disabled"
                ScrollViewer.VerticalScrollBarVisibility="Hidden">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="MinHeight" Value="17" />
                        <Setter Property="Padding" Value="4,1" />
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="Clipboard:ClipboardEntry">
                        <Grid ColumnSpacing="5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <FontIcon
                                VerticalAlignment="Center"
                                FontSize="10"
                                Foreground="{ThemeResource GlanceClipboardIconBrush}"
                                Glyph="{x:Bind Glyph}" />
                            <TextBlock
                                Grid.Column="1"
                                VerticalAlignment="Center"
                                FontSize="10"
                                MaxLines="1"
                                Text="{x:Bind Preview}"
                                TextTrimming="CharacterEllipsis" />
                            <TextBlock
                                Grid.Column="2"
                                VerticalAlignment="Center"
                                FontSize="9"
                                Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                Text="{x:Bind TimeText}" />
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </StackPanel>
    </Grid>
</UserControl>

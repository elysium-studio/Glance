<UserControl
    x:Class="Glance.Clipboard.WinUI.ClipboardExpandedView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Clipboard="using:Glance.Clipboard"
    xmlns:Controls="using:Elysium.UI.Controls.WinUI">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Themes/Clipboard.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <Style
                x:Key="ClipboardActionButtonStyle"
                BasedOn="{StaticResource SubtleButtonStyle}"
                TargetType="Button">
                <Setter Property="Width" Value="32" />
                <Setter Property="Height" Value="32" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="CornerRadius" Value="{ThemeResource ControlCornerRadius}" />
                <Setter Property="FontFamily" Value="Segoe Fluent Icons" />
                <Setter Property="FontSize" Value="14" />
            </Style>
            <DataTemplate x:Key="ClipboardItemTemplate" x:DataType="Clipboard:ClipboardEntry">
                <Grid Margin="2,0,0,0" ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel
                        VerticalAlignment="Center"
                        Spacing="1"
                        ToolTipService.ToolTip="{x:Bind Preview}">
                        <TextBlock
                            MaxLines="1"
                            Style="{StaticResource BodyStrongTextBlockStyle}"
                            Text="{x:Bind Preview}"
                            TextTrimming="CharacterEllipsis"
                            TextWrapping="NoWrap" />
                        <StackPanel Orientation="Horizontal" Spacing="5">
                            <TextBlock
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Style="{StaticResource CaptionTextBlockStyle}"
                                Text="{x:Bind KindLabel}" />
                            <TextBlock
                                Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                Style="{StaticResource CaptionTextBlockStyle}"
                                Text="&#x2022;" />
                            <TextBlock
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                Style="{StaticResource CaptionTextBlockStyle}"
                                Text="{x:Bind TimeText}" />
                        </StackPanel>
                    </StackPanel>
                    <StackPanel
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        Orientation="Horizontal"
                        Spacing="2">
                        <Button
                            x:Uid="CopyButton"
                            Click="HandleCopyClick"
                            Content="&#xE8C8;"
                            Style="{StaticResource ClipboardActionButtonStyle}" />
                        <Button
                            x:Uid="SendButton"
                            Click="HandlePasteClick"
                            Content="&#xE72D;"
                            Style="{StaticResource ClipboardActionButtonStyle}" />
                        <Button
                            x:Uid="RemoveButton"
                            Click="HandleRemoveClick"
                            Content="&#xE74D;"
                            Style="{StaticResource ClipboardActionButtonStyle}" />
                    </StackPanel>
                </Grid>
            </DataTemplate>
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid Padding="20,12,20,26">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid
            x:Name="StatusIndicator"
            Width="36"
            Height="36"
            VerticalAlignment="Center">
            <FontIcon
                Width="30"
                Height="30"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontFamily="Segoe Fluent Icons"
                FontSize="30"
                Foreground="{ThemeResource GlanceClipboardIconBrush}"
                Glyph="&#xF0E3;" />
        </Grid>
        <Grid
            Grid.Column="1"
            Height="58"
            Margin="12,0,0,0"
            VerticalAlignment="Center"
            RowSpacing="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="14" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <TextBlock
                FontWeight="SemiBold"
                Foreground="{ThemeResource GlanceClipboardIconBrush}"
                Style="{StaticResource CaptionTextBlockStyle}"
                Text="{x:Bind ToUpper(ViewModel.Title)}" />
            <TextBlock
                x:Uid="EmptyMessage"
                Grid.Row="1"
                Margin="0,2,0,0"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Style="{StaticResource BodyTextBlockStyle}"
                Visibility="{x:Bind WhenEmpty(ViewModel.CanClearHistory), Mode=OneWay}" />
            <Controls:CompactFlipView
                x:Name="ClipboardFlipView"
                Grid.Row="1"
                Margin="-22,0,0,0"
                Background="Transparent"
                ItemTemplate="{StaticResource ClipboardItemTemplate}"
                ItemsSource="{x:Bind ViewModel.ShelfItems}"
                SelectedItem="{x:Bind ViewModel.SelectedEntry, Mode=TwoWay}"
                Visibility="{x:Bind WhenPopulated(ViewModel.CanClearHistory), Mode=OneWay}" />
        </Grid>
    </Grid>
</UserControl>

<UserControl
    x:Class="Glance.Clipboard.WinUI.ClipboardExpandedView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Clipboard="using:Glance.Clipboard">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Themes/Clipboard.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <Style x:Key="ClipboardShelfItemStyle" TargetType="ListViewItem">
                <Setter Property="MinWidth" Value="0" />
                <Setter Property="MinHeight" Value="0" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="Margin" Value="0,0,4,0" />
                <Setter Property="CornerRadius" Value="6" />
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid Padding="16,9,16,28" RowSpacing="5">
        <Grid.RowDefinitions>
            <RowDefinition Height="42" />
            <RowDefinition Height="24" />
        </Grid.RowDefinitions>
        <Grid ColumnSpacing="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="30" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <FontIcon
                x:Name="StatusIndicator"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontFamily="Segoe Fluent Icons"
                FontSize="27"
                Foreground="{ThemeResource GlanceClipboardIconBrush}"
                Glyph="&#xF0E3;" />
            <StackPanel
                Grid.Column="1"
                VerticalAlignment="Center"
                Spacing="1">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock
                        FontSize="11"
                        FontWeight="SemiBold"
                        Foreground="{ThemeResource GlanceClipboardIconBrush}"
                        Text="{x:Bind ToUpper(ViewModel.Title)}" />
                    <TextBlock
                        FontSize="11"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="{x:Bind ToKind(ViewModel.SelectedEntry), Mode=OneWay}" />
                </StackPanel>
                <TextBlock
                    FontSize="15"
                    FontWeight="SemiBold"
                    MaxLines="1"
                    Text="{x:Bind ToPreview(ViewModel.SelectedEntry), Mode=OneWay}"
                    TextTrimming="CharacterEllipsis"
                    TextWrapping="NoWrap" />
            </StackPanel>
            <StackPanel
                Grid.Column="2"
                VerticalAlignment="Center"
                Orientation="Horizontal"
                Spacing="4">
                <Button
                    Width="28"
                    Height="28"
                    Padding="0"
                    AutomationProperties.Name="Copy selected clip"
                    Click="{x:Bind HandleCopyClick}"
                    Content="&#xE8C8;"
                    CornerRadius="14"
                    FontFamily="Segoe Fluent Icons"
                    FontSize="11"
                    IsEnabled="{x:Bind ViewModel.CanUseSelectedEntry, Mode=OneWay}"
                    ToolTipService.ToolTip="Copy" />
                <Button
                    Width="30"
                    Height="30"
                    Padding="0"
                    AutomationProperties.Name="Send selected clip to focused app"
                    Click="{x:Bind HandlePasteClick}"
                    Content="&#xE72D;"
                    CornerRadius="15"
                    FontFamily="Segoe Fluent Icons"
                    FontSize="12"
                    IsEnabled="{x:Bind ViewModel.CanUseSelectedEntry, Mode=OneWay}"
                    Style="{StaticResource AccentButtonStyle}"
                    ToolTipService.ToolTip="Send to focused app" />
                <Button
                    Width="28"
                    Height="28"
                    Padding="0"
                    AutomationProperties.Name="Remove selected clip"
                    Click="{x:Bind HandleRemoveClick}"
                    Content="&#xE74D;"
                    CornerRadius="14"
                    FontFamily="Segoe Fluent Icons"
                    FontSize="11"
                    IsEnabled="{x:Bind ViewModel.CanUseSelectedEntry, Mode=OneWay}"
                    ToolTipService.ToolTip="Remove" />
                <Button
                    Width="28"
                    Height="28"
                    Padding="0"
                    AutomationProperties.Name="Clear clipboard shelf"
                    Background="Transparent"
                    BorderThickness="0"
                    Click="{x:Bind HandleClearClick}"
                    Content="&#xE894;"
                    CornerRadius="14"
                    FontFamily="Segoe Fluent Icons"
                    FontSize="11"
                    IsEnabled="{x:Bind ViewModel.CanClearHistory, Mode=OneWay}"
                    ToolTipService.ToolTip="Clear shelf" />
            </StackPanel>
        </Grid>
        <ListView
            Grid.Row="1"
            ItemContainerStyle="{StaticResource ClipboardShelfItemStyle}"
            ItemsSource="{x:Bind ViewModel.ShelfItems}"
            SelectedItem="{x:Bind ViewModel.SelectedEntry, Mode=TwoWay}"
            SelectionMode="Single"
            ScrollViewer.HorizontalScrollBarVisibility="Hidden"
            ScrollViewer.HorizontalScrollMode="Enabled"
            ScrollViewer.VerticalScrollBarVisibility="Disabled"
            ScrollViewer.VerticalScrollMode="Disabled">
            <ListView.ItemsPanel>
                <ItemsPanelTemplate>
                    <ItemsStackPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </ListView.ItemsPanel>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="Clipboard:ClipboardEntry">
                    <Grid
                        Width="92"
                        Height="24"
                        Padding="6,0"
                        ColumnSpacing="5"
                        ToolTipService.ToolTip="{x:Bind Preview}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <FontIcon
                            VerticalAlignment="Center"
                            FontFamily="Segoe Fluent Icons"
                            FontSize="11"
                            Foreground="{ThemeResource GlanceClipboardIconBrush}"
                            Glyph="{x:Bind Glyph}" />
                        <TextBlock
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            FontSize="11"
                            MaxLines="1"
                            Text="{x:Bind Preview}"
                            TextTrimming="CharacterEllipsis"
                            TextWrapping="NoWrap" />
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</UserControl>

<UserControl
    x:Class="Glance.Clipboard.WinUI.ClipboardExpandedView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Clipboard="using:Glance.Clipboard">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Themes/Clipboard.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <Style x:Key="ClipboardShelfItemStyle" TargetType="ListViewItem">
                <Setter Property="MinWidth" Value="0" />
                <Setter Property="MinHeight" Value="0" />
                <Setter Property="Padding" Value="0" />
                <Setter Property="Margin" Value="0,0,6,0" />
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                <Setter Property="Background" Value="Transparent" />
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid Padding="14,8,14,28" RowSpacing="4">
        <Grid.RowDefinitions>
            <RowDefinition Height="20" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid ColumnSpacing="7">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <FontIcon
                x:Name="StatusIndicator"
                VerticalAlignment="Center"
                FontFamily="Segoe Fluent Icons"
                FontSize="16"
                Foreground="{ThemeResource GlanceClipboardIconBrush}"
                Glyph="&#xF0E3;" />
            <TextBlock
                Grid.Column="1"
                VerticalAlignment="Center"
                FontSize="11"
                FontWeight="SemiBold"
                Foreground="{ThemeResource GlanceClipboardIconBrush}"
                Text="{x:Bind ToUpper(ViewModel.Title)}" />
            <TextBlock
                Grid.Column="2"
                VerticalAlignment="Center"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Style="{StaticResource CaptionTextBlockStyle}"
                Text="{x:Bind ViewModel.HistoryStatus, Mode=OneWay}"
                TextTrimming="CharacterEllipsis" />
            <Button
                Grid.Column="3"
                Width="22"
                Height="22"
                Padding="0"
                AutomationProperties.Name="Clear clipboard history"
                Background="Transparent"
                BorderThickness="0"
                Click="{x:Bind HandleClearClick}"
                Content="&#xE894;"
                CornerRadius="5"
                FontFamily="Segoe Fluent Icons"
                FontSize="11"
                IsEnabled="{x:Bind ViewModel.CanClearHistory, Mode=OneWay}"
                ToolTipService.ToolTip="Clear clipboard history" />
        </Grid>
        <ListView
            Grid.Row="1"
            IsItemClickEnabled="False"
            ItemContainerStyle="{StaticResource ClipboardShelfItemStyle}"
            ItemsSource="{x:Bind ViewModel.ShelfItems}"
            SelectionMode="None"
            ScrollViewer.HorizontalScrollBarVisibility="Hidden"
            ScrollViewer.HorizontalScrollMode="Enabled"
            ScrollViewer.VerticalScrollBarVisibility="Disabled"
            ScrollViewer.VerticalScrollMode="Disabled">
            <ListView.ItemsPanel>
                <ItemsPanelTemplate>
                    <ItemsStackPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </ListView.ItemsPanel>
            <ListView.ItemTemplate>
                <DataTemplate x:DataType="Clipboard:ClipboardEntry">
                    <Border
                        Width="108"
                        Height="50"
                        Padding="7,5"
                        Background="{ThemeResource ControlFillColorSecondaryBrush}"
                        CornerRadius="8"
                        ToolTipService.ToolTip="{x:Bind Preview}">
                        <Grid ColumnSpacing="6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="18" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <FontIcon
                                VerticalAlignment="Top"
                                FontFamily="Segoe Fluent Icons"
                                FontSize="14"
                                Foreground="{ThemeResource GlanceClipboardIconBrush}"
                                Glyph="{x:Bind Glyph}" />
                            <Grid Grid.Column="1">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="20" />
                                    <RowDefinition Height="20" />
                                </Grid.RowDefinitions>
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontSize="11"
                                    FontWeight="SemiBold"
                                    Text="{x:Bind Preview}"
                                    TextTrimming="CharacterEllipsis"
                                    TextWrapping="NoWrap" />
                                <StackPanel
                                    Grid.Row="1"
                                    HorizontalAlignment="Right"
                                    Orientation="Horizontal"
                                    Spacing="1">
                                    <Button
                                        Width="20"
                                        Height="20"
                                        Padding="0"
                                        AutomationProperties.Name="Copy"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Click="HandleCopyClick"
                                        Content="&#xE8C8;"
                                        CornerRadius="4"
                                        FontFamily="Segoe Fluent Icons"
                                        FontSize="9"
                                        Tag="{x:Bind}"
                                        ToolTipService.ToolTip="Copy" />
                                    <Button
                                        Width="20"
                                        Height="20"
                                        Padding="0"
                                        AutomationProperties.Name="Send to focused app"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Click="HandlePasteClick"
                                        Content="&#xE72D;"
                                        CornerRadius="4"
                                        FontFamily="Segoe Fluent Icons"
                                        FontSize="9"
                                        Tag="{x:Bind}"
                                        ToolTipService.ToolTip="Send to focused app" />
                                    <Button
                                        Width="20"
                                        Height="20"
                                        Padding="0"
                                        AutomationProperties.Name="Remove"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Click="HandleRemoveClick"
                                        Content="&#xE74D;"
                                        CornerRadius="4"
                                        FontFamily="Segoe Fluent Icons"
                                        FontSize="9"
                                        Tag="{x:Bind}"
                                        ToolTipService.ToolTip="Remove" />
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</UserControl>

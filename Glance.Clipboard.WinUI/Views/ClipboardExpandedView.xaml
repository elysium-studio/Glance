<UserControl
    x:Class="Glance.Clipboard.WinUI.ClipboardExpandedView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Clipboard="using:Glance.Clipboard">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Themes/Clipboard.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <Style x:Key="ClipboardFlipViewItemStyle" TargetType="FlipViewItem">
                <Setter Property="Padding" Value="0" />
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                <Setter Property="VerticalContentAlignment" Value="Stretch" />
            </Style>
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid Padding="14,8,14,28">
        <FlipView
            x:Name="ClipboardFlipView"
            Height="58"
            Padding="0"
            VerticalAlignment="Center"
            Background="Transparent"
            BorderThickness="0"
            ItemContainerStyle="{StaticResource ClipboardFlipViewItemStyle}"
            ItemsSource="{x:Bind ViewModel.ShelfItems}"
            SelectedItem="{x:Bind ViewModel.SelectedEntry, Mode=TwoWay}">
            <FlipView.ItemTemplate>
                <DataTemplate x:DataType="Clipboard:ClipboardEntry">
                    <Grid Padding="34,0" ColumnSpacing="9">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="28" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <FontIcon
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontFamily="Segoe Fluent Icons"
                            FontSize="20"
                            Foreground="{ThemeResource GlanceClipboardIconBrush}"
                            Glyph="{x:Bind Glyph}" />
                        <StackPanel
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            Spacing="1"
                            ToolTipService.ToolTip="{x:Bind Preview}">
                            <TextBlock
                                FontSize="14"
                                FontWeight="SemiBold"
                                MaxLines="1"
                                Text="{x:Bind Preview}"
                                TextTrimming="CharacterEllipsis"
                                TextWrapping="NoWrap" />
                            <StackPanel Orientation="Horizontal" Spacing="5">
                                <TextBlock
                                    FontSize="10"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="{x:Bind KindLabel}" />
                                <TextBlock
                                    FontSize="10"
                                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                    Text="•" />
                                <TextBlock
                                    FontSize="10"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Text="{x:Bind TimeText}" />
                            </StackPanel>
                        </StackPanel>
                        <StackPanel
                            Grid.Column="2"
                            VerticalAlignment="Center"
                            Orientation="Horizontal"
                            Spacing="3">
                            <Button
                                Width="27"
                                Height="27"
                                Padding="0"
                                AutomationProperties.Name="Copy this clip"
                                Click="HandleCopyClick"
                                Content="&#xE8C8;"
                                CornerRadius="14"
                                FontFamily="Segoe Fluent Icons"
                                FontSize="11"
                                ToolTipService.ToolTip="Copy" />
                            <Button
                                Width="29"
                                Height="29"
                                Padding="0"
                                AutomationProperties.Name="Send this clip to focused app"
                                Click="HandlePasteClick"
                                Content="&#xE72D;"
                                CornerRadius="15"
                                FontFamily="Segoe Fluent Icons"
                                FontSize="12"
                                Style="{StaticResource AccentButtonStyle}"
                                ToolTipService.ToolTip="Send to focused app" />
                            <Button
                                Width="27"
                                Height="27"
                                Padding="0"
                                AutomationProperties.Name="Remove this clip"
                                Click="HandleRemoveClick"
                                Content="&#xE74D;"
                                CornerRadius="14"
                                FontFamily="Segoe Fluent Icons"
                                FontSize="11"
                                ToolTipService.ToolTip="Remove" />
                            <Button
                                Width="27"
                                Height="27"
                                Padding="0"
                                AutomationProperties.Name="Clear clipboard shelf"
                                Background="Transparent"
                                BorderThickness="0"
                                Click="HandleClearClick"
                                Content="&#xE894;"
                                CornerRadius="14"
                                FontFamily="Segoe Fluent Icons"
                                FontSize="11"
                                ToolTipService.ToolTip="Clear shelf" />
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </FlipView.ItemTemplate>
        </FlipView>
    </Grid>
</UserControl>

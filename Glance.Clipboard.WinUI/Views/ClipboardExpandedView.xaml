 
<UserControl
    x:Class="Glance.Clipboard.WinUI.ClipboardExpandedView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:Clipboard="using:Glance.Clipboard">
    <UserControl.Resources>
        <ResourceDictionary Source="../Themes/Clipboard.xaml" />
    </UserControl.Resources>
    <Grid Padding="16,10,16,26" ColumnSpacing="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid
            x:Name="StatusIndicator"
            Width="36"
            Height="36"
            VerticalAlignment="Center">
            <FontIcon
                Width="30"
                Height="30"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontFamily="Segoe Fluent Icons"
                FontSize="30"
                Foreground="{ThemeResource GlanceClipboardIconBrush}"
                Glyph="&#xF0E3;" />
        </Grid>
        <StackPanel
            Grid.Column="1"
            VerticalAlignment="Center"
            Spacing="1">
            <TextBlock
                FontSize="11"
                FontWeight="SemiBold"
                Foreground="{ThemeResource GlanceClipboardIconBrush}"
                Text="CLIPBOARD" />
            <TextBlock
                FontWeight="SemiBold"
                MaxLines="2"
                Style="{StaticResource BodyLargeTextBlockStyle}"
                Text="{Binding LatestPreview}"
                TextTrimming="CharacterEllipsis"
                TextWrapping="NoWrap" />
            <TextBlock
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Style="{StaticResource CaptionTextBlockStyle}"
                Text="{Binding LatestKind}"
                TextTrimming="CharacterEllipsis"
                TextWrapping="NoWrap" />
        </StackPanel>
    </Grid>
</UserControl>

<UserControl
    x:Class="Glance.Clipboard.WinUI.ClipboardCompactView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Padding="10,0" ColumnSpacing="8">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid
            x:Name="StatusIndicator"
            Width="30"
            Height="26">
            <Viewbox
                Width="22"
                Height="22"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
                <Canvas Width="14" Height="14">
                    <Path
                        Data="M 5,2.5 L 3.5,2.5 C 2.7,2.5 2,3.2 2,4 L 2,11.5 C 2,12.3 2.7,13 3.5,13 L 10.5,13 C 11.3,13 12,12.3 12,11.5 L 12,4 C 12,3.2 11.3,2.5 10.5,2.5 L 9,2.5 M 5,1 L 9,1 L 9,4 L 5,4 Z"
                        Stroke="{ThemeResource GlanceClipboardIconBrush}"
                        StrokeEndLineCap="Round"
                        StrokeLineJoin="Round"
                        StrokeStartLineCap="Round"
                        StrokeThickness="0.9" />
                </Canvas>
            </Viewbox>
        </Grid>
        <StackPanel
            Grid.Column="1"
            VerticalAlignment="Center"
            Spacing="0">
            <TextBlock
                FontSize="13"
                FontWeight="SemiBold"
                MaxLines="1"
                Text="{Binding LatestPreview}"
                TextTrimming="CharacterEllipsis" />
            <TextBlock
                FontSize="10"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="{Binding LatestKind}" />
        </StackPanel>
    </Grid>
</UserControl>

<UserControl
    x:Class="Glance.DropShelf.WinUI.DropShelfExpandedView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:DropShelf="using:Glance.DropShelf">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Themes/DropShelf.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <DataTemplate x:Key="DropShelfItemTemplate" x:DataType="DropShelf:DropShelfItem">
                <Border
                    Width="96"
                    Height="36"
                    Padding="7,0,3,0"
                    Background="{ThemeResource ControlFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    ToolTipService.ToolTip="{x:Bind Path}">
                    <Grid ColumnSpacing="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <FontIcon
                            VerticalAlignment="Center"
                            FontFamily="Segoe Fluent Icons"
                            FontSize="14"
                            Foreground="{ThemeResource GlanceDropShelfIconBrush}"
                            Glyph="{x:Bind Glyph}" />
                        <TextBlock
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            MaxLines="1"
                            Style="{StaticResource CaptionTextBlockStyle}"
                            Text="{x:Bind Name}"
                            TextTrimming="CharacterEllipsis"
                            TextWrapping="NoWrap" />
                        <Button
                            x:Uid="RemoveShelfItemButton"
                            Grid.Column="2"
                            Width="22"
                            Height="22"
                            Padding="0"
                            VerticalAlignment="Center"
                            Click="HandleRemoveItemClick"
                            Content="&#xE711;"
                            FontFamily="Segoe Fluent Icons"
                            FontSize="12"
                            Style="{StaticResource SubtleButtonStyle}" />
                    </Grid>
                </Border>
            </DataTemplate>
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid Padding="20,12,20,26">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid
            x:Name="StatusIndicator"
            Width="36"
            Height="36"
            VerticalAlignment="Center">
            <FontIcon
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontFamily="Segoe Fluent Icons"
                FontSize="30"
                Foreground="{ThemeResource GlanceDropShelfIconBrush}"
                Glyph="&#xE8B7;" />
        </Grid>
        <Grid
            Grid.Column="1"
            Height="58"
            Margin="18,0,0,0"
            VerticalAlignment="Center"
            RowSpacing="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="14" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <TextBlock
                FontWeight="SemiBold"
                Foreground="{ThemeResource GlanceDropShelfIconBrush}"
                Style="{StaticResource CaptionTextBlockStyle}"
                Text="{x:Bind ToUpper(ViewModel.Title)}" />
            <TextBlock
                Grid.Row="1"
                Margin="0,2,0,0"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Style="{StaticResource BodyTextBlockStyle}"
                Text="{x:Bind ViewModel.Summary, Mode=OneWay}"
                TextTrimming="CharacterEllipsis"
                TextWrapping="NoWrap"
                Visibility="{x:Bind WhenEmpty(ViewModel.HasItems), Mode=OneWay}" />
            <Grid
                Grid.Row="1"
                ColumnSpacing="6"
                Visibility="{x:Bind WhenPopulated(ViewModel.HasItems), Mode=OneWay}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ScrollViewer
                    HorizontalScrollBarVisibility="Hidden"
                    HorizontalScrollMode="Enabled"
                    VerticalScrollBarVisibility="Disabled"
                    VerticalScrollMode="Disabled">
                    <ItemsControl ItemTemplate="{StaticResource DropShelfItemTemplate}" ItemsSource="{x:Bind ViewModel.Items}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="5" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                </ScrollViewer>
                <Border
                    x:Uid="MoveShelfButton"
                    Grid.Column="1"
                    Width="32"
                    Height="32"
                    VerticalAlignment="Center"
                    Background="{ThemeResource SubtleFillColorTransparentBrush}"
                    CanDrag="True"
                    CornerRadius="6"
                    DragStarting="HandleDragStarting"
                    DropCompleted="HandleDropCompleted">
                    <FontIcon
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontFamily="Segoe Fluent Icons"
                        FontSize="14"
                        Foreground="{ThemeResource GlanceDropShelfIconBrush}"
                        Glyph="&#xE7C2;"
                        IsHitTestVisible="False" />
                </Border>
            </Grid>
        </Grid>
    </Grid>
</UserControl>

<UserControl
    x:Class="Glance.DropShelf.WinUI.DropShelfExpandedView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:DropShelf="using:Glance.DropShelf">
    <UserControl.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="../Themes/DropShelf.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <DataTemplate x:Key="DropShelfItemTemplate" x:DataType="DropShelf:DropShelfItem">
                <Border
                    Width="58"
                    Height="40"
                    Padding="4,3"
                    Background="{ThemeResource ControlFillColorSecondaryBrush}"
                    CornerRadius="6"
                    ToolTipService.ToolTip="{x:Bind Path}">
                    <StackPanel HorizontalAlignment="Center" Spacing="1">
                        <FontIcon
                            FontFamily="Segoe Fluent Icons"
                            FontSize="15"
                            Foreground="{ThemeResource GlanceDropShelfIconBrush}"
                            Glyph="{x:Bind Glyph}" />
                        <TextBlock
                            Width="48"
                            HorizontalTextAlignment="Center"
                            FontSize="9"
                            MaxLines="1"
                            Text="{x:Bind Name}"
                            TextTrimming="CharacterEllipsis"
                            TextWrapping="NoWrap" />
                    </StackPanel>
                </Border>
            </DataTemplate>
        </ResourceDictionary>
    </UserControl.Resources>
    <Grid Padding="20,12,16,26" ColumnSpacing="14">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <Grid
            x:Name="StatusIndicator"
            Width="36"
            Height="36"
            VerticalAlignment="Center">
            <FontIcon
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontFamily="Segoe Fluent Icons"
                FontSize="32"
                Foreground="{ThemeResource GlanceDropShelfIconBrush}"
                Glyph="&#xE8B7;" />
        </Grid>
        <Grid
            Grid.Column="1"
            Height="62"
            VerticalAlignment="Center"
            RowSpacing="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="14" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <TextBlock
                FontSize="11"
                FontWeight="SemiBold"
                Foreground="{ThemeResource GlanceDropShelfIconBrush}"
                Text="{x:Bind ToUpper(ViewModel.Title)}" />
            <TextBlock
                Grid.Row="1"
                VerticalAlignment="Center"
                FontSize="14"
                FontWeight="SemiBold"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="{x:Bind ViewModel.Summary, Mode=OneWay}"
                Visibility="{x:Bind WhenEmpty(ViewModel.HasItems), Mode=OneWay}" />
            <Border
                x:Name="ShelfDragSurface"
                Grid.Row="1"
                Padding="5,3,8,3"
                Background="{ThemeResource GlanceDropShelfSurfaceBrush}"
                BorderBrush="{ThemeResource GlanceDropShelfStrokeBrush}"
                BorderThickness="1"
                CanDrag="{x:Bind ViewModel.HasItems, Mode=OneWay}"
                CornerRadius="8"
                DragStarting="HandleDragStarting"
                DropCompleted="HandleDropCompleted"
                Visibility="{x:Bind WhenPopulated(ViewModel.HasItems), Mode=OneWay}">
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ScrollViewer
                        HorizontalScrollBarVisibility="Hidden"
                        HorizontalScrollMode="Enabled"
                        VerticalScrollBarVisibility="Disabled"
                        VerticalScrollMode="Disabled">
                        <ItemsControl
                            IsHitTestVisible="False"
                            ItemTemplate="{StaticResource DropShelfItemTemplate}"
                            ItemsSource="{x:Bind ViewModel.Items}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="5" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </ScrollViewer>
                    <FontIcon
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        FontFamily="Segoe Fluent Icons"
                        FontSize="15"
                        Foreground="{ThemeResource GlanceDropShelfIconBrush}"
                        Glyph="&#xE7C2;" />
                </Grid>
            </Border>
        </Grid>
        <Button
            x:Uid="ClearShelfButton"
            Grid.Column="2"
            Width="32"
            Height="32"
            Padding="0"
            VerticalAlignment="Center"
            Background="Transparent"
            BorderThickness="0"
            Click="{x:Bind ViewModel.Clear}"
            Content="&#xE74D;"
            FontFamily="Segoe Fluent Icons"
            FontSize="12"
            Visibility="{x:Bind WhenPopulated(ViewModel.HasItems), Mode=OneWay}" />
    </Grid>
</UserControl>

<UserControl
    x:Class="Glance.Stopwatch.WinUI.StopwatchCompactView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid x:Name="LayoutRoot" Padding="10,0">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid
            x:Name="StatusIndicator"
            Width="26"
            Height="26"
            UseLayoutRounding="True">
            <Viewbox
                Width="24"
                Height="24"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
                <Canvas Width="14" Height="14">
                    <Ellipse
                        Canvas.Left="2.25"
                        Canvas.Top="3.25"
                        Width="9.5"
                        Height="9.5"
                        Stroke="{ThemeResource GlanceStopwatchIconBrush}"
                        StrokeThickness="0.9" />
                    <Path
                        Data="M 5.4,1.25 L 8.6,1.25 M 7,1.25 L 7,3.25 M 10.15,3.4 L 11.2,4.45 M 7,5.5 L 7,8 L 8.7,9"
                        Stroke="{ThemeResource GlanceStopwatchIconBrush}"
                        StrokeEndLineCap="Round"
                        StrokeLineJoin="Round"
                        StrokeStartLineCap="Round"
                        StrokeThickness="0.9" />
                </Canvas>
            </Viewbox>
        </Grid>
        <TextBlock
            Grid.Column="1"
            Margin="8,0,0,0"
            VerticalAlignment="Center"
            FontSize="15"
            FontWeight="SemiBold"
            Foreground="{ThemeResource TextFillColorPrimaryBrush}"
            Text="{Binding Elapsed}" />
    </Grid>
</UserControl>

<UserControl
    x:Class="Glance.Stopwatch.WinUI.StopwatchExpandedView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid x:Name="LayoutRoot" Padding="20,12,20,26">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <Grid
            x:Name="StatusIndicator"
            Width="36"
            Height="36"
            VerticalAlignment="Center"
            UseLayoutRounding="True">
            <Viewbox
                Width="30"
                Height="30"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
                <Canvas Width="14" Height="14">
                    <Ellipse
                        Canvas.Left="2.25"
                        Canvas.Top="3.25"
                        Width="9.5"
                        Height="9.5"
                        Stroke="{ThemeResource GlanceStopwatchIconBrush}"
                        StrokeThickness="0.9" />
                    <Path
                        Data="M 5.4,1.25 L 8.6,1.25 M 7,1.25 L 7,3.25 M 10.15,3.4 L 11.2,4.45 M 7,5.5 L 7,8 L 8.7,9"
                        Stroke="{ThemeResource GlanceStopwatchIconBrush}"
                        StrokeEndLineCap="Round"
                        StrokeLineJoin="Round"
                        StrokeStartLineCap="Round"
                        StrokeThickness="0.9" />
                </Canvas>
            </Viewbox>
        </Grid>
        <StackPanel
            Grid.Column="1"
            Margin="12,0,16,0"
            VerticalAlignment="Center"
            Spacing="2">
            <TextBlock
                FontSize="11"
                FontWeight="SemiBold"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="STOPWATCH" />
            <TextBlock
                FontSize="27"
                FontWeight="SemiBold"
                Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                Text="{Binding Elapsed}" />
        </StackPanel>
        <StackPanel
            Grid.Column="2"
            VerticalAlignment="Center"
            Orientation="Horizontal"
            Spacing="6">
            <Button
                Height="32"
                MinWidth="68"
                Padding="16,0"
                Command="{Binding ToggleCommand}"
                Content="{Binding ToggleText}"
                CornerRadius="16"
                Style="{StaticResource AccentButtonStyle}" />
            <Button
                Height="32"
                MinWidth="64"
                Padding="16,0"
                Command="{Binding ResetCommand}"
                Content="Reset"
                CornerRadius="16" />
        </StackPanel>
    </Grid>
</UserControl>

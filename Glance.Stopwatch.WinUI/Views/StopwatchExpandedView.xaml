<UserControl
    x:Class="Glance.Stopwatch.WinUI.StopwatchExpandedView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid x:Name="LayoutRoot" Padding="20,12,20,26">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <Grid
            x:Name="StatusIndicator"
            Width="36"
            Height="36"
            VerticalAlignment="Center">
            <FontIcon
                Width="30"
                Height="30"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontFamily="Segoe Fluent Icons"
                FontSize="30"
                Foreground="{ThemeResource GlanceStopwatchIconBrush}"
                Glyph="&#xE916;" />
        </Grid>
        <StackPanel
            Grid.Column="1"
            Margin="12,0,16,0"
            VerticalAlignment="Center"
            Spacing="2">
            <TextBlock
                FontSize="11"
                FontWeight="SemiBold"
                Foreground="{ThemeResource GlanceStopwatchIconBrush}"
                Text="STOPWATCH" />
            <TextBlock
                FontSize="27"
                FontWeight="SemiBold"
                Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                Text="{Binding Elapsed}" />
        </StackPanel>
        <StackPanel
            Grid.Column="2"
            VerticalAlignment="Center"
            Orientation="Horizontal"
            Spacing="6">
            <Button
                Height="32"
                MinWidth="68"
                Padding="16,0"
                Command="{Binding ToggleCommand}"
                Content="{Binding ToggleText}"
                CornerRadius="16"
                Style="{StaticResource AccentButtonStyle}" />
            <Button
                Height="32"
                MinWidth="64"
                Padding="16,0"
                Command="{Binding ResetCommand}"
                Content="Reset"
                CornerRadius="16" />
        </StackPanel>
    </Grid>
</UserControl>

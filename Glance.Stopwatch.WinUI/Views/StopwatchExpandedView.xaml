<UserControl
    x:Class="Glance.Stopwatch.WinUI.StopwatchExpandedView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <ResourceDictionary Source="../Themes/Stopwatch.xaml" />
    </UserControl.Resources>
    <Grid
        x:Name="LayoutRoot"
        Padding="20,12,20,26"
        ColumnSpacing="18">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <Grid
            x:Name="StatusIndicator"
            Width="36"
            Height="36"
            VerticalAlignment="Center">
            <FontIcon
                Width="30"
                Height="30"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontFamily="Segoe Fluent Icons"
                FontSize="30"
                Foreground="{ThemeResource GlanceStopwatchIconBrush}"
                Glyph="&#xE916;" />
        </Grid>
        <StackPanel
            Grid.Column="1"
            VerticalAlignment="Center"
            Spacing="2">
            <TextBlock
                FontWeight="SemiBold"
                Foreground="{ThemeResource GlanceStopwatchIconBrush}"
                Style="{StaticResource CaptionTextBlockStyle}"
                Text="{x:Bind ToUpper(Title)}" />
            <TextBlock
                Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                Style="{StaticResource TitleTextBlockStyle}"
                Text="{x:Bind ViewModel.Elapsed, Mode=OneWay}" />
        </StackPanel>
        <StackPanel
            Grid.Column="2"
            VerticalAlignment="Center"
            Orientation="Horizontal"
            Spacing="6">
            <Button
                x:Uid="ToggleButton"
                Width="36"
                Height="36"
                Padding="0"
                Click="{x:Bind ViewModel.Toggle}"
                Content="{x:Bind ViewModel.ToggleGlyph, Mode=OneWay}"
                CornerRadius="18"
                FontFamily="Segoe Fluent Icons"
                FontSize="16"
                Style="{StaticResource AccentButtonStyle}" />
            <Button
                x:Uid="ResetButton"
                Width="32"
                Height="32"
                Padding="0"
                Click="{x:Bind ViewModel.Reset}"
                Content="&#xE777;"
                CornerRadius="16"
                FontFamily="Segoe Fluent Icons"
                FontSize="14" />
        </StackPanel>
    </Grid>
</UserControl>
